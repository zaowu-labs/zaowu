{
  "name": "zaowu",
  "version": "0.0.1",
  "description": "ZaoWu is an open-source AI-powered toolkit for development, automation, documents, data, and workflows.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ZaoWu Labs",
  "homepage": "https://github.com/zaowu-labs/zaowu",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaowu-labs/zaowu.git"
  },
  "keywords": [
    "ai",
    "cli",
    "development",
    "automation",
    "toolkit"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --recursive run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "dev": "pnpm --recursive run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=8.0.0"
  }
}
