{
  "name": "zaowu",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "description": "Open-source AI toolkit for development, automation, documents, data, teaching, plugins, and workflows.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ZaoWu Labs",
  "homepage": "https://github.com/zaowu-labs/zaowu",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaowu-labs/zaowu.git"
  },
  "keywords": [
    "ai",
    "cli",
    "development",
    "automation",
    "toolkit"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "verify": "corepack pnpm build && corepack pnpm verify:schemas && corepack pnpm verify:fixtures && corepack pnpm verify:json-contracts && corepack pnpm verify:capabilities && corepack pnpm verify:smoke && corepack pnpm test && corepack pnpm lint && corepack pnpm format:check && corepack pnpm verify:release && corepack pnpm pack:check && corepack pnpm verify:pack-install",
    "verify:schemas": "node scripts/verify-schemas.mjs",
    "verify:fixtures": "node scripts/verify-rich-fixtures.mjs",
    "verify:json-contracts": "node scripts/verify-json-contracts.mjs",
    "verify:capabilities": "node scripts/verify-command-capability-matrix.mjs",
    "verify:release": "node scripts/verify-release-readiness.mjs",
    "verify:smoke": "node scripts/verify-cli-smoke.mjs",
    "verify:pack-install": "node scripts/verify-packed-cli.mjs",
    "pack:check": "corepack pnpm --filter \"./packages/*\" pack --dry-run",
    "dev": "corepack pnpm --recursive run dev",
    "zw": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^1.0.0",
    "ajv": "^8.20.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.34.1 <11"
  }
}
