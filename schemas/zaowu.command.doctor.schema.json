{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.doctor.schema.json",
  "title": "ZaoWu Doctor Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "checks", "nextSteps", "operationPlan"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "enum": ["ok", "warning"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "enum": ["ok", "warning", "missing"]
          },
          "version": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    },
    "nextSteps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operationPlan": {
      "$ref": "https://schemas.zaowu.dev/zaowu.command.shared.schema.json#/$defs/operationPlan"
    }
  }
}
