{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.data-schema.schema.json",
  "title": "ZaoWu Data Schema Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "filePath", "columns"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "ok"
    },
    "filePath": {
      "type": "string"
    },
    "sheetName": {
      "type": "string"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["column", "index", "type", "nullable", "examples"],
        "properties": {
          "column": {
            "type": "string"
          },
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "type": {
            "enum": ["number", "boolean", "string", "empty", "mixed"]
          },
          "nullable": {
            "type": "boolean"
          },
          "examples": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
