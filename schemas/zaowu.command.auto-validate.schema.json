{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.auto-validate.schema.json",
  "title": "ZaoWu Auto Validate Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "filePath", "workflow", "policy", "sandbox", "warnings"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "ok"
    },
    "filePath": {
      "type": "string"
    },
    "workflow": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "name", "variables", "permissions", "steps"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "shell", "fileWrites", "network"],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "shell": {
          "enum": ["blocked", "prompt"]
        },
        "fileWrites": {
          "enum": ["blocked", "prompt"]
        },
        "network": {
          "enum": ["blocked", "prompt"]
        }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "root", "shellCommands", "fileWrites", "network"],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "root": {
          "const": "workflow-directory"
        },
        "shellCommands": {
          "const": "blocked"
        },
        "fileWrites": {
          "const": "blocked"
        },
        "network": {
          "const": "blocked"
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
