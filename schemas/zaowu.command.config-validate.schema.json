{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.config-validate.schema.json",
  "title": "ZaoWu Config Validate Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "filePath", "config", "warnings"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "enum": ["ok", "warning"]
    },
    "filePath": {
      "type": "string"
    },
    "config": {
      "$ref": "https://schemas.zaowu.dev/zaowu.config.schema.json"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
