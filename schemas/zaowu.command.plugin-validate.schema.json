{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.plugin-validate.schema.json",
  "title": "ZaoWu Plugin Validate Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "target", "warnings", "errors"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "enum": ["ok", "warning"]
    },
    "target": {
      "type": "string"
    },
    "manifestPath": {
      "type": "string"
    },
    "manifest": {
      "$ref": "https://schemas.zaowu.dev/zaowu.plugin.schema.json"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
