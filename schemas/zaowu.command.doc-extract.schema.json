{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.doc-extract.schema.json",
  "title": "ZaoWu Doc Extract Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "status",
    "filePath",
    "headings",
    "links",
    "codeBlockCount",
    "frontmatter"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "ok"
    },
    "filePath": {
      "type": "string"
    },
    "headings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "codeBlockCount": {
      "type": "integer",
      "minimum": 0
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
