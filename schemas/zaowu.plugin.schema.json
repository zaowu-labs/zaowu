{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.plugin.schema.json",
  "title": "ZaoWu Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Plugin manifest schema version supported by this foundation release."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  }
}
