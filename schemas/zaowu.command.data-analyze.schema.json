{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.data-analyze.schema.json",
  "title": "ZaoWu Data Analyze Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "filePath", "numericColumns"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "ok"
    },
    "filePath": {
      "type": "string"
    },
    "sheetName": {
      "type": "string"
    },
    "numericColumns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["column", "count", "min", "max", "average"],
        "properties": {
          "column": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          },
          "average": {
            "type": "number"
          }
        }
      }
    }
  }
}
