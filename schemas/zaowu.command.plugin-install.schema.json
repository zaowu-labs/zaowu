{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.plugin-install.schema.json",
  "title": "ZaoWu Plugin Install Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "status", "pluginDir", "plugin", "wroteFile"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "enum": ["ok", "preview"]
    },
    "pluginDir": {
      "type": "string"
    },
    "plugin": {
      "$ref": "#/$defs/pluginManifest"
    },
    "wroteFile": {
      "type": "boolean"
    },
    "operationPlan": {
      "$ref": "https://schemas.zaowu.dev/zaowu.command.shared.schema.json#/$defs/operationPlan"
    }
  },
  "$defs": {
    "pluginManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "installedAt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "installedAt": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
