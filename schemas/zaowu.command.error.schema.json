{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zaowu.dev/zaowu.command.error.schema.json",
  "title": "ZaoWu Command Error Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "why", "fix", "exitCode"],
      "properties": {
        "code": {
          "enum": [
            "AI_INPUT_FILE_READ_FAILED",
            "AI_INPUT_TOO_LARGE",
            "AI_NETWORK_CONFIRMATION_REQUIRED",
            "AI_PROMPT_REQUIRED",
            "AI_PROVIDER_CONFIG_MISSING",
            "AI_PROVIDER_NOT_FOUND",
            "AI_PROVIDER_REQUEST_FAILED",
            "AI_PROVIDER_RESPONSE_INVALID",
            "COMMAND_HANDLER_MISSING",
            "COMMAND_NOT_IMPLEMENTED",
            "CONFIG_ALREADY_EXISTS",
            "CONFIG_FORMAT_UNSUPPORTED",
            "CONFIG_KEY_UNSUPPORTED",
            "CONFIG_NOT_FOUND",
            "CONFIG_PARSE_FAILED",
            "CONFIG_SECRET_KEY_NOT_ALLOWED",
            "CONFIG_VALUE_INVALID",
            "CONFIG_VERSION_UNSUPPORTED",
            "CONFIG_WRITE_FAILED",
            "DATA_FORMAT_UNSUPPORTED",
            "DATA_OUTPUT_CONFLICT",
            "DATA_READ_FAILED",
            "DATA_SHEET_NOT_FOUND",
            "DATA_WRITE_FAILED",
            "DOCUMENT_FORMAT_UNSUPPORTED",
            "DOCUMENT_OUTPUT_CONFLICT",
            "DOCUMENT_READ_FAILED",
            "DOCUMENT_SEARCH_KEYWORD_REQUIRED",
            "DOCUMENT_WRITE_FAILED",
            "GIT_COMMAND_FAILED",
            "INTERNAL_ERROR",
            "NO_CHANGES_TO_REVIEW",
            "NO_STAGED_CHANGES",
            "PLUGIN_ID_INVALID",
            "PLUGIN_ALREADY_INSTALLED",
            "PLUGIN_NOT_INSTALLED",
            "PLUGIN_SOURCE_ID_MISMATCH",
            "PLUGIN_SOURCE_INVALID",
            "PLUGIN_WRITE_FAILED",
            "TARGET_REQUIRED",
            "TEACH_INPUT_REQUIRED",
            "UNKNOWN_COMMAND",
            "UNKNOWN_DOMAIN_ACTION",
            "WEB_FETCH_UNAVAILABLE",
            "WEB_URL_INVALID",
            "WORKFLOW_FORMAT_UNSUPPORTED",
            "WORKFLOW_PARSE_FAILED",
            "WORKFLOW_READ_FAILED"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": ["string", "null"]
        },
        "fix": {
          "type": ["string", "null"]
        },
        "exitCode": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
